<?xml version="1.0" encoding="UTF-8"?>
<!--
    Maven settings for Nexus deployment
    Copy this to ~/.m2/settings.xml and update with your credentials

    Usage:
    1. Copy to ~/.m2/settings.xml
    2. Update <username> and <password> with your Nexus credentials
    3. Build with: mvn deploy -s ~/.m2/settings.xml

    Or set environment variables:
    - NEXUS_USER
    - NEXUS_PASS
-->
<settings>
    <servers>
        <server>
            <id>deploy-release</id>
            <username>YOUR_NEXUS_USERNAME</username>
            <password>YOUR_NEXUS_PASSWORD</password>
        </server>
        <server>
            <id>deploy-snapshot</id>
            <username>YOUR_NEXUS_USERNAME</username>
            <password>YOUR_NEXUS_PASSWORD</password>
        </server>
    </servers>
</settings>
